# Project Configuration Template
# Copy to .env.dev, .env.prod, or .env.test and fill in actual values.
# DO NOT commit secrets to version control.

# ============================================================================
# PROJECT SETTINGS
# ============================================================================
PROJECT_NAME=text-to-sql-agent
PROJECT_VERSION=0.1.0
ENVIRONMENT=dev
DEBUG=true
VERBOSE=false

# Execution mode: sync or async
EXECUTION_MODE=async

# Request timeouts (seconds)
REQUEST_TIMEOUT=30
QUERY_TIMEOUT=60

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=text
# JSON format recommended for prod (format: json or text)
LOG_OUTPUT=stdout
# File path for log output (optional, leave empty for stdout)
LOG_FILE=

# Per-module log levels (optional overrides)
LOG_LEVEL_AGENT=DEBUG
LOG_LEVEL_SERVICE=DEBUG
LOG_LEVEL_REPOSITORY=DEBUG

# ============================================================================
# DATABASE CONFIGURATION - SQLite
# ============================================================================
DB_DRIVER=sqlite
# SQLite file path (absolute or relative to project root)
SQLITE_PATH=data/text_to_sql.db
SQLITE_JOURNAL_MODE=WAL
SQLITE_TIMEOUT=30
SQLITE_FOREIGN_KEYS=true

# ============================================================================
# DATABASE CONFIGURATION - PostgreSQL (optional)
# ============================================================================
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=
PG_DATABASE=text_to_sql
PG_SSL_MODE=prefer
PG_POOL_MIN_SIZE=5
PG_POOL_MAX_SIZE=20
PG_POOL_TIMEOUT=30
PG_CONNECTION_TIMEOUT=10
PG_QUERY_TIMEOUT=60

# ============================================================================
# DATABASE CONFIGURATION - Athena (AWS)
# ============================================================================
ATHENA_AWS_REGION=us-east-1
ATHENA_S3_OUTPUT_LOCATION=s3://your-bucket/athena-results/
ATHENA_WORKGROUP=primary
ATHENA_CATALOG=AwsDataCatalog
ATHENA_SCHEMA=default
ATHENA_TIMEOUT=120

# AWS Credentials (use IAM roles in prod, env vars or ~/.aws in dev)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

# ============================================================================
# DATABASE CONFIGURATION - MySQL
# ============================================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=text_to_sql
MYSQL_CHARSET=utf8mb4
MYSQL_SSL_ENABLED=false
MYSQL_POOL_MIN_SIZE=5
MYSQL_POOL_MAX_SIZE=20
MYSQL_CONNECTION_TIMEOUT=10
MYSQL_QUERY_TIMEOUT=60

# ============================================================================
# LLM CONFIGURATION
# ============================================================================
LLM_PROVIDER=openai
# Provider options: openai, anthropic, local, azure

# Model settings
LLM_MODEL=gpt-4-turbo
LLM_API_KEY=
LLM_API_ENDPOINT=https://api.openai.com/v1
LLM_ORGANIZATION_ID=

# Generation parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TOP_P=0.9
LLM_FREQUENCY_PENALTY=0.0
LLM_PRESENCE_PENALTY=0.0

# Timeouts and retries
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=3
LLM_RETRY_STRATEGY=exponential
# exponential: exponential backoff, fixed: fixed delay
LLM_RETRY_DELAY=1

# Rate limiting
LLM_RATE_LIMIT_REQUESTS_PER_MIN=60
LLM_RATE_LIMIT_TOKENS_PER_MIN=90000
LLM_CIRCUIT_BREAKER_THRESHOLD=5
LLM_CIRCUIT_BREAKER_TIMEOUT=60

# Cost control
LLM_COST_ESTIMATION_ENABLED=true
LLM_COST_BUDGET_PER_DAY=10.0
# Cost budget per day in USD (0 = unlimited)
LLM_TOKEN_COUNTING_STRATEGY=api_response
# Strategies: api_response, estimate, count

# Model fallback
LLM_FALLBACK_MODEL=gpt-3.5-turbo
# Fallback model for graceful degradation
LLM_MODEL_SWITCHING_STRATEGY=least_cost
# Strategies: round_robin, least_cost, best_quality

# ============================================================================
# CACHING CONFIGURATION
# ============================================================================
CACHE_ENABLED=true
CACHE_BACKEND=memory
# Backends: memory, redis

# Redis config (if backend=redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=text_to_sql:
REDIS_TTL=3600

# In-memory cache config
CACHE_MAX_SIZE=1000
CACHE_EVICTION_POLICY=lru
# Policies: lru (least recently used), lfu (least frequently used)

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_SQL_VALIDATION=true
FEATURE_SAFETY_VALIDATORS=true
FEATURE_EXPERIMENTAL_MODELS=false
FEATURE_AUDIT_LOGGING=true
FEATURE_HOT_RELOAD_CONFIG=false
FEATURE_REQUEST_DEDUPLICATION=true

# ============================================================================
# RATE LIMITING & CONCURRENCY
# ============================================================================
RATE_LIMIT_REQUESTS_PER_USER_PER_MIN=30
RATE_LIMIT_REQUESTS_PER_SESSION_PER_MIN=100
RATE_LIMIT_GLOBAL_QUEUE_DEPTH=1000

# ============================================================================
# SQL VALIDATION RULES
# ============================================================================
SQL_VALIDATION_ENABLED=true
SQL_MAX_TABLE_JOINS=5
SQL_MAX_SUBQUERIES=3
SQL_INJECTION_CHECK=true
SQL_COMPLEXITY_LIMIT=medium
# Levels: low, medium, high

# ============================================================================
# SECRETS MANAGEMENT
# ============================================================================
SECRETS_BACKEND=env
# Backends: env, aws_secrets_manager, vault

# AWS Secrets Manager (if backend=aws_secrets_manager)
SECRETS_AWS_REGION=us-east-1
SECRETS_AWS_SECRET_NAME=text-to-sql-agent/prod

# HashiCorp Vault (if backend=vault)
VAULT_ADDR=https://vault.example.com
VAULT_TOKEN=
VAULT_PATH=secret/text-to-sql-agent

# ============================================================================
# OBSERVABILITY & TELEMETRY
# ============================================================================
TELEMETRY_ENABLED=true
TELEMETRY_ENDPOINT=http://localhost:4317
# OpenTelemetry gRPC endpoint
TELEMETRY_BATCH_SIZE=512
TELEMETRY_EXPORT_INTERVAL=5000

# Metrics export
METRICS_ENABLED=true
METRICS_EXPORT_FORMAT=prometheus
# Formats: prometheus, datadog, cloudwatch
METRICS_EXPORT_ENDPOINT=http://localhost:8888/metrics

# Tracing
TRACING_ENABLED=true
TRACING_SAMPLE_RATE=0.1
# Sample 10% of requests

# ============================================================================
# AUDIT LOGGING
# ============================================================================
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_COMPRESSION=gzip
AUDIT_QUERIES_HISTORY_ENABLED=true
AUDIT_QUERIES_HISTORY_RETENTION_DAYS=30

# ============================================================================
# DATABASE MIGRATIONS
# ============================================================================
DATABASE_AUTO_MIGRATE=false
DATABASE_MIGRATION_STRATEGY=safe
# Strategies: safe (require manual approval), auto (auto-migrate)
DATABASE_ROLLBACK_ENABLED=true

# ============================================================================
# REQUEST/RESPONSE VALIDATION
# ============================================================================
VALIDATION_STRICT_MODE=true
VALIDATION_SCHEMA_VERSION=1.0
VALIDATION_ERROR_HANDLING=reject
# Handling modes: reject (fail), warn (log warning, continue), ignore

# ============================================================================
# MULTI-TENANT SUPPORT
# ============================================================================
MULTI_TENANT_ENABLED=false
TENANT_ISOLATION_LEVEL=full
# Levels: none, logical, full
TENANT_CONTEXT_KEY=tenant_id

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_VERSION=v1
API_PORT=8000
API_HOST=0.0.0.0
API_CORS_ENABLED=true
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================================================
# MONITORING & HEALTH CHECKS
# ============================================================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=60
# seconds
SLA_RESPONSE_TIME_MS=5000
SLA_SUCCESS_RATE_PERCENT=99.0
ALERTING_ENDPOINT=http://localhost:9093/api/v1/alerts
# Prometheus Alertmanager or custom webhook
