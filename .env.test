# .env.test - Testing & CI/CD Environment
# Used for automated tests, CI pipelines, and integration testing.
# Optimized for speed and isolation from external services.

PROJECT_NAME=text-to-sql-agent
PROJECT_VERSION=0.1.0
ENVIRONMENT=test
DEBUG=true
VERBOSE=false

EXECUTION_MODE=sync
# Use sync for deterministic test execution

REQUEST_TIMEOUT=10
QUERY_TIMEOUT=20

# ============================================================================
# LOGGING - Testing (Minimal)
# ============================================================================
LOG_LEVEL=WARNING
LOG_FORMAT=text
LOG_OUTPUT=stdout
LOG_FILE=

LOG_LEVEL_AGENT=WARNING
LOG_LEVEL_SERVICE=WARNING
LOG_LEVEL_REPOSITORY=ERROR

# ============================================================================
# DATABASE - SQLite (In-Memory/Temp)
# ============================================================================
DB_DRIVER=sqlite
SQLITE_PATH=:memory:
# Use in-memory database for fast tests
SQLITE_JOURNAL_MODE=MEMORY
SQLITE_TIMEOUT=5
SQLITE_FOREIGN_KEYS=true

# ============================================================================
# DATABASE - PostgreSQL (Test Container)
# ============================================================================
PG_HOST=localhost
PG_PORT=5433
PG_USER=test_user
PG_PASSWORD=test_password
PG_DATABASE=text_to_sql_test
PG_SSL_MODE=disable
PG_POOL_MIN_SIZE=1
PG_POOL_MAX_SIZE=3
PG_POOL_TIMEOUT=5
PG_CONNECTION_TIMEOUT=3
PG_QUERY_TIMEOUT=10

# ============================================================================
# DATABASE - Athena (Mocked)
# ============================================================================
ATHENA_AWS_REGION=us-east-1
ATHENA_S3_OUTPUT_LOCATION=s3://test-bucket/results/
ATHENA_WORKGROUP=test
ATHENA_CATALOG=AwsDataCatalog
ATHENA_SCHEMA=test
ATHENA_TIMEOUT=5

AWS_ACCESS_KEY_ID=test_key
AWS_SECRET_ACCESS_KEY=test_secret
AWS_SESSION_TOKEN=

# ============================================================================
# DATABASE - MySQL (Test Container)
# ============================================================================
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USER=test_user
MYSQL_PASSWORD=test_password
MYSQL_DATABASE=text_to_sql_test
MYSQL_CHARSET=utf8mb4
MYSQL_SSL_ENABLED=false
MYSQL_POOL_MIN_SIZE=1
MYSQL_POOL_MAX_SIZE=3
MYSQL_CONNECTION_TIMEOUT=3
MYSQL_QUERY_TIMEOUT=10

# ============================================================================
# LLM - Testing (Mocked/Stubbed)
# ============================================================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo
LLM_API_KEY=sk-test_dummy_key_for_unit_tests
LLM_API_ENDPOINT=http://localhost:8081/mock-llm
# Mock LLM server for testing
LLM_ORGANIZATION_ID=

LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=100
LLM_TOP_P=1.0
LLM_FREQUENCY_PENALTY=0.0
LLM_PRESENCE_PENALTY=0.0

LLM_REQUEST_TIMEOUT=5
LLM_MAX_RETRIES=1
LLM_RETRY_STRATEGY=fixed
LLM_RETRY_DELAY=0.1

LLM_RATE_LIMIT_REQUESTS_PER_MIN=1000
LLM_RATE_LIMIT_TOKENS_PER_MIN=999999
LLM_CIRCUIT_BREAKER_THRESHOLD=100
LLM_CIRCUIT_BREAKER_TIMEOUT=60

LLM_COST_ESTIMATION_ENABLED=false
LLM_COST_BUDGET_PER_DAY=0.0
LLM_TOKEN_COUNTING_STRATEGY=estimate

LLM_FALLBACK_MODEL=gpt-3.5-turbo
LLM_MODEL_SWITCHING_STRATEGY=round_robin

# ============================================================================
# CACHING - Testing (In-Memory, Small)
# ============================================================================
CACHE_ENABLED=true
CACHE_BACKEND=memory

REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=test:
REDIS_TTL=60

CACHE_MAX_SIZE=100
CACHE_EVICTION_POLICY=lru

# ============================================================================
# FEATURE FLAGS - Testing (All Enabled)
# ============================================================================
FEATURE_SQL_VALIDATION=true
FEATURE_SAFETY_VALIDATORS=true
FEATURE_EXPERIMENTAL_MODELS=true
FEATURE_AUDIT_LOGGING=false
FEATURE_HOT_RELOAD_CONFIG=false
FEATURE_REQUEST_DEDUPLICATION=false

# ============================================================================
# RATE LIMITING - Testing (Disabled)
# ============================================================================
RATE_LIMIT_REQUESTS_PER_USER_PER_MIN=999999
RATE_LIMIT_REQUESTS_PER_SESSION_PER_MIN=999999
RATE_LIMIT_GLOBAL_QUEUE_DEPTH=999999

# ============================================================================
# SQL VALIDATION - Testing (Permissive)
# ============================================================================
SQL_VALIDATION_ENABLED=true
SQL_MAX_TABLE_JOINS=20
SQL_MAX_SUBQUERIES=10
SQL_INJECTION_CHECK=true
SQL_COMPLEXITY_LIMIT=high

# ============================================================================
# SECRETS - Testing (Mock)
# ============================================================================
SECRETS_BACKEND=env

SECRETS_AWS_REGION=us-east-1
SECRETS_AWS_SECRET_NAME=test/secrets

VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=test_token
VAULT_PATH=secret/test

# ============================================================================
# OBSERVABILITY - Testing (Disabled)
# ============================================================================
TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=http://localhost:4317
TELEMETRY_BATCH_SIZE=512
TELEMETRY_EXPORT_INTERVAL=5000

METRICS_ENABLED=false
METRICS_EXPORT_FORMAT=prometheus
METRICS_EXPORT_ENDPOINT=http://localhost:8888/metrics

TRACING_ENABLED=false
TRACING_SAMPLE_RATE=0.0

# ============================================================================
# AUDIT LOGGING - Testing (Disabled)
# ============================================================================
AUDIT_LOG_ENABLED=false
AUDIT_LOG_RETENTION_DAYS=1
AUDIT_LOG_COMPRESSION=none
AUDIT_QUERIES_HISTORY_ENABLED=false
AUDIT_QUERIES_HISTORY_RETENTION_DAYS=1

# ============================================================================
# DATABASE MIGRATIONS - Testing (Auto)
# ============================================================================
DATABASE_AUTO_MIGRATE=true
DATABASE_MIGRATION_STRATEGY=auto
DATABASE_ROLLBACK_ENABLED=true

# ============================================================================
# VALIDATION - Testing (Permissive)
# ============================================================================
VALIDATION_STRICT_MODE=false
VALIDATION_SCHEMA_VERSION=1.0
VALIDATION_ERROR_HANDLING=warn

# ============================================================================
# MULTI-TENANT - Testing (Disabled)
# ============================================================================
MULTI_TENANT_ENABLED=false
TENANT_ISOLATION_LEVEL=none
TENANT_CONTEXT_KEY=tenant_id

# ============================================================================
# API - Testing
# ============================================================================
API_VERSION=v1
API_PORT=8001
API_HOST=127.0.0.1
API_CORS_ENABLED=true
API_CORS_ORIGINS=*

# ============================================================================
# MONITORING - Testing (Minimal)
# ============================================================================
HEALTH_CHECK_ENABLED=false
HEALTH_CHECK_INTERVAL=60
SLA_RESPONSE_TIME_MS=10000
SLA_SUCCESS_RATE_PERCENT=95.0
ALERTING_ENDPOINT=http://localhost:9093/api/v1/alerts
