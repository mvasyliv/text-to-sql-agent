# .env.prod - Production Environment
# WARNING: This file should NOT be committed to version control.
# Load secrets from AWS Secrets Manager, HashiCorp Vault, or environment variables.
# All sensitive values are marked with [LOAD_FROM_SECRETS].

PROJECT_NAME=text-to-sql-agent
PROJECT_VERSION=0.1.0
ENVIRONMENT=prod
DEBUG=false
VERBOSE=false

EXECUTION_MODE=async

REQUEST_TIMEOUT=30
QUERY_TIMEOUT=60

# ============================================================================
# LOGGING - Production (Structured JSON)
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_OUTPUT=stdout
LOG_FILE=/var/log/text-to-sql-agent/app.log

LOG_LEVEL_AGENT=INFO
LOG_LEVEL_SERVICE=INFO
LOG_LEVEL_REPOSITORY=WARNING

# ============================================================================
# DATABASE - SQLite (Persistent)
# ============================================================================
DB_DRIVER=postgresql
# Primary driver is PostgreSQL for production
SQLITE_PATH=/data/text_to_sql.db
SQLITE_JOURNAL_MODE=WAL
SQLITE_TIMEOUT=30
SQLITE_FOREIGN_KEYS=true

# ============================================================================
# DATABASE - PostgreSQL (Primary for Production)
# ============================================================================
PG_HOST=[LOAD_FROM_SECRETS]
PG_PORT=5432
PG_USER=[LOAD_FROM_SECRETS]
PG_PASSWORD=[LOAD_FROM_SECRETS]
PG_DATABASE=text_to_sql_prod
PG_SSL_MODE=require
PG_POOL_MIN_SIZE=10
PG_POOL_MAX_SIZE=50
PG_POOL_TIMEOUT=30
PG_CONNECTION_TIMEOUT=10
PG_QUERY_TIMEOUT=60

# ============================================================================
# DATABASE - Athena (AWS Analytics)
# ============================================================================
ATHENA_AWS_REGION=us-east-1
ATHENA_S3_OUTPUT_LOCATION=[LOAD_FROM_SECRETS]
ATHENA_WORKGROUP=production
ATHENA_CATALOG=AwsDataCatalog
ATHENA_SCHEMA=text_to_sql_prod
ATHENA_TIMEOUT=120

AWS_ACCESS_KEY_ID=[LOAD_FROM_SECRETS]
AWS_SECRET_ACCESS_KEY=[LOAD_FROM_SECRETS]
AWS_SESSION_TOKEN=[LOAD_FROM_SECRETS]

# ============================================================================
# DATABASE - MySQL (Optional Secondary)
# ============================================================================
MYSQL_HOST=[LOAD_FROM_SECRETS]
MYSQL_PORT=3306
MYSQL_USER=[LOAD_FROM_SECRETS]
MYSQL_PASSWORD=[LOAD_FROM_SECRETS]
MYSQL_DATABASE=text_to_sql_prod
MYSQL_CHARSET=utf8mb4
MYSQL_SSL_ENABLED=true
MYSQL_POOL_MIN_SIZE=10
MYSQL_POOL_MAX_SIZE=50
MYSQL_CONNECTION_TIMEOUT=10
MYSQL_QUERY_TIMEOUT=60

# ============================================================================
# LLM - Production (Claude + GPT-4 with Fallback)
# ============================================================================
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-opus-20240229
LLM_API_KEY=[LOAD_FROM_SECRETS]
LLM_API_ENDPOINT=https://api.anthropic.com
LLM_ORGANIZATION_ID=[LOAD_FROM_SECRETS]

LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TOP_P=0.9
LLM_FREQUENCY_PENALTY=0.5
LLM_PRESENCE_PENALTY=0.5

LLM_REQUEST_TIMEOUT=90
LLM_MAX_RETRIES=5
LLM_RETRY_STRATEGY=exponential
LLM_RETRY_DELAY=2

LLM_RATE_LIMIT_REQUESTS_PER_MIN=100
LLM_RATE_LIMIT_TOKENS_PER_MIN=200000
LLM_CIRCUIT_BREAKER_THRESHOLD=10
LLM_CIRCUIT_BREAKER_TIMEOUT=300

LLM_COST_ESTIMATION_ENABLED=true
LLM_COST_BUDGET_PER_DAY=100.0
LLM_TOKEN_COUNTING_STRATEGY=api_response

LLM_FALLBACK_MODEL=gpt-4-turbo
LLM_MODEL_SWITCHING_STRATEGY=best_quality

# ============================================================================
# CACHING - Production (Redis Cluster)
# ============================================================================
CACHE_ENABLED=true
CACHE_BACKEND=redis

REDIS_HOST=[LOAD_FROM_SECRETS]
REDIS_PORT=6379
REDIS_PASSWORD=[LOAD_FROM_SECRETS]
REDIS_DB=0
REDIS_KEY_PREFIX=text_to_sql_prod:
REDIS_TTL=7200

CACHE_MAX_SIZE=10000
CACHE_EVICTION_POLICY=lru

# ============================================================================
# FEATURE FLAGS - Production
# ============================================================================
FEATURE_SQL_VALIDATION=true
FEATURE_SAFETY_VALIDATORS=true
FEATURE_EXPERIMENTAL_MODELS=false
FEATURE_AUDIT_LOGGING=true
FEATURE_HOT_RELOAD_CONFIG=false
FEATURE_REQUEST_DEDUPLICATION=true

# ============================================================================
# RATE LIMITING - Production (Strict)
# ============================================================================
RATE_LIMIT_REQUESTS_PER_USER_PER_MIN=60
RATE_LIMIT_REQUESTS_PER_SESSION_PER_MIN=300
RATE_LIMIT_GLOBAL_QUEUE_DEPTH=5000

# ============================================================================
# SQL VALIDATION - Production (Strict)
# ============================================================================
SQL_VALIDATION_ENABLED=true
SQL_MAX_TABLE_JOINS=3
SQL_MAX_SUBQUERIES=2
SQL_INJECTION_CHECK=true
SQL_COMPLEXITY_LIMIT=medium

# ============================================================================
# SECRETS MANAGEMENT - Production
# ============================================================================
SECRETS_BACKEND=aws_secrets_manager

SECRETS_AWS_REGION=us-east-1
SECRETS_AWS_SECRET_NAME=text-to-sql-agent/prod

VAULT_ADDR=[LOAD_FROM_SECRETS]
VAULT_TOKEN=[LOAD_FROM_SECRETS]
VAULT_PATH=secret/text-to-sql-agent/prod

# ============================================================================
# OBSERVABILITY - Production (Full)
# ============================================================================
TELEMETRY_ENABLED=true
TELEMETRY_ENDPOINT=http://otel-collector.monitoring.svc.cluster.local:4317
TELEMETRY_BATCH_SIZE=1024
TELEMETRY_EXPORT_INTERVAL=5000

METRICS_ENABLED=true
METRICS_EXPORT_FORMAT=prometheus
METRICS_EXPORT_ENDPOINT=http://prometheus-pushgateway.monitoring.svc.cluster.local:9091

TRACING_ENABLED=true
TRACING_SAMPLE_RATE=0.1

# ============================================================================
# AUDIT LOGGING - Production (Full)
# ============================================================================
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365
AUDIT_LOG_COMPRESSION=gzip
AUDIT_QUERIES_HISTORY_ENABLED=true
AUDIT_QUERIES_HISTORY_RETENTION_DAYS=90

# ============================================================================
# DATABASE MIGRATIONS - Production (Safe)
# ============================================================================
DATABASE_AUTO_MIGRATE=false
DATABASE_MIGRATION_STRATEGY=safe
DATABASE_ROLLBACK_ENABLED=true

# ============================================================================
# VALIDATION - Production (Strict)
# ============================================================================
VALIDATION_STRICT_MODE=true
VALIDATION_SCHEMA_VERSION=1.0
VALIDATION_ERROR_HANDLING=reject

# ============================================================================
# MULTI-TENANT - Production
# ============================================================================
MULTI_TENANT_ENABLED=true
TENANT_ISOLATION_LEVEL=full
TENANT_CONTEXT_KEY=tenant_id

# ============================================================================
# API - Production
# ============================================================================
API_VERSION=v1
API_PORT=8000
API_HOST=0.0.0.0
API_CORS_ENABLED=true
API_CORS_ORIGINS=https://app.example.com,https://api.example.com

# ============================================================================
# MONITORING & ALERTING - Production
# ============================================================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30
SLA_RESPONSE_TIME_MS=3000
SLA_SUCCESS_RATE_PERCENT=99.9
ALERTING_ENDPOINT=https://alertmanager.monitoring.example.com/api/v1/alerts
