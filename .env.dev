# .env.dev - Local Development Environment
# Use this for local development on your machine.
# All values point to localhost or test databases.

PROJECT_NAME=text-to-sql-agent
PROJECT_VERSION=0.1.0
ENVIRONMENT=dev
DEBUG=true
VERBOSE=true

EXECUTION_MODE=async

REQUEST_TIMEOUT=30
QUERY_TIMEOUT=60

# ============================================================================
# LOGGING - Development
# ============================================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=text
LOG_OUTPUT=stdout
LOG_FILE=

LOG_LEVEL_AGENT=DEBUG
LOG_LEVEL_SERVICE=DEBUG
LOG_LEVEL_REPOSITORY=DEBUG

# ============================================================================
# DATABASE - SQLite (Local)
# ============================================================================
DB_DRIVER=sqlite
SQLITE_PATH=data/dev.db
SQLITE_JOURNAL_MODE=WAL
SQLITE_TIMEOUT=30
SQLITE_FOREIGN_KEYS=true

# ============================================================================
# DATABASE - PostgreSQL (Optional Local)
# ============================================================================
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=postgres_dev_password
PG_DATABASE=text_to_sql_dev
PG_SSL_MODE=disable
PG_POOL_MIN_SIZE=2
PG_POOL_MAX_SIZE=5
PG_POOL_TIMEOUT=10
PG_CONNECTION_TIMEOUT=5
PG_QUERY_TIMEOUT=30

# ============================================================================
# DATABASE - Athena (Disabled for Dev)
# ============================================================================
ATHENA_AWS_REGION=us-east-1
ATHENA_S3_OUTPUT_LOCATION=s3://my-dev-bucket/athena-results/
ATHENA_WORKGROUP=primary
ATHENA_CATALOG=AwsDataCatalog
ATHENA_SCHEMA=default
ATHENA_TIMEOUT=120

AWS_ACCESS_KEY_ID=dev_key_not_used
AWS_SECRET_ACCESS_KEY=dev_secret_not_used
AWS_SESSION_TOKEN=

# ============================================================================
# DATABASE - MySQL (Optional Local)
# ============================================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root_dev_password
MYSQL_DATABASE=text_to_sql_dev
MYSQL_CHARSET=utf8mb4
MYSQL_SSL_ENABLED=false
MYSQL_POOL_MIN_SIZE=2
MYSQL_POOL_MAX_SIZE=5
MYSQL_CONNECTION_TIMEOUT=5
MYSQL_QUERY_TIMEOUT=30

# ============================================================================
# LLM - Development (OpenAI with test key)
# ============================================================================
LLM_PROVIDER=openai
LLM_MODEL=gpt-4-turbo
LLM_API_KEY=sk-test_your_openai_api_key_here
LLM_API_ENDPOINT=https://api.openai.com/v1
LLM_ORGANIZATION_ID=

LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000
LLM_TOP_P=0.9
LLM_FREQUENCY_PENALTY=0.0
LLM_PRESENCE_PENALTY=0.0

LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=2
LLM_RETRY_STRATEGY=exponential
LLM_RETRY_DELAY=1

LLM_RATE_LIMIT_REQUESTS_PER_MIN=30
LLM_RATE_LIMIT_TOKENS_PER_MIN=50000
LLM_CIRCUIT_BREAKER_THRESHOLD=5
LLM_CIRCUIT_BREAKER_TIMEOUT=60

LLM_COST_ESTIMATION_ENABLED=true
LLM_COST_BUDGET_PER_DAY=5.0
LLM_TOKEN_COUNTING_STRATEGY=estimate

LLM_FALLBACK_MODEL=gpt-3.5-turbo
LLM_MODEL_SWITCHING_STRATEGY=least_cost

# ============================================================================
# CACHING - Development (In-memory)
# ============================================================================
CACHE_ENABLED=true
CACHE_BACKEND=memory

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=text_to_sql_dev:
REDIS_TTL=3600

CACHE_MAX_SIZE=500
CACHE_EVICTION_POLICY=lru

# ============================================================================
# FEATURE FLAGS - Development
# ============================================================================
FEATURE_SQL_VALIDATION=true
FEATURE_SAFETY_VALIDATORS=true
FEATURE_EXPERIMENTAL_MODELS=true
FEATURE_AUDIT_LOGGING=false
FEATURE_HOT_RELOAD_CONFIG=true
FEATURE_REQUEST_DEDUPLICATION=false

# ============================================================================
# RATE LIMITING - Development
# ============================================================================
RATE_LIMIT_REQUESTS_PER_USER_PER_MIN=1000
RATE_LIMIT_REQUESTS_PER_SESSION_PER_MIN=10000
RATE_LIMIT_GLOBAL_QUEUE_DEPTH=5000

# ============================================================================
# SQL VALIDATION - Development
# ============================================================================
SQL_VALIDATION_ENABLED=true
SQL_MAX_TABLE_JOINS=10
SQL_MAX_SUBQUERIES=5
SQL_INJECTION_CHECK=true
SQL_COMPLEXITY_LIMIT=high

# ============================================================================
# SECRETS - Development
# ============================================================================
SECRETS_BACKEND=env

SECRETS_AWS_REGION=us-east-1
SECRETS_AWS_SECRET_NAME=text-to-sql-agent/dev

VAULT_ADDR=https://vault.local
VAULT_TOKEN=dev_token_not_used
VAULT_PATH=secret/text-to-sql-agent

# ============================================================================
# OBSERVABILITY - Development
# ============================================================================
TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=http://localhost:4317
TELEMETRY_BATCH_SIZE=512
TELEMETRY_EXPORT_INTERVAL=5000

METRICS_ENABLED=false
METRICS_EXPORT_FORMAT=prometheus
METRICS_EXPORT_ENDPOINT=http://localhost:8888/metrics

TRACING_ENABLED=false
TRACING_SAMPLE_RATE=1.0

# ============================================================================
# AUDIT LOGGING - Development
# ============================================================================
AUDIT_LOG_ENABLED=false
AUDIT_LOG_RETENTION_DAYS=7
AUDIT_LOG_COMPRESSION=none
AUDIT_QUERIES_HISTORY_ENABLED=false
AUDIT_QUERIES_HISTORY_RETENTION_DAYS=1

# ============================================================================
# DATABASE MIGRATIONS - Development
# ============================================================================
DATABASE_AUTO_MIGRATE=true
DATABASE_MIGRATION_STRATEGY=auto
DATABASE_ROLLBACK_ENABLED=true

# ============================================================================
# VALIDATION - Development
# ============================================================================
VALIDATION_STRICT_MODE=false
VALIDATION_SCHEMA_VERSION=1.0
VALIDATION_ERROR_HANDLING=warn

# ============================================================================
# MULTI-TENANT - Development
# ============================================================================
MULTI_TENANT_ENABLED=false
TENANT_ISOLATION_LEVEL=none
TENANT_CONTEXT_KEY=tenant_id

# ============================================================================
# API - Development
# ============================================================================
API_VERSION=v1
API_PORT=8000
API_HOST=localhost
API_CORS_ENABLED=true
API_CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# ============================================================================
# MONITORING - Development
# ============================================================================
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=60
SLA_RESPONSE_TIME_MS=10000
SLA_SUCCESS_RATE_PERCENT=95.0
ALERTING_ENDPOINT=http://localhost:9093/api/v1/alerts
